{
  "name": "opennews/emergencymode-news",
  "description": "Testing dependencies for emergencymode.news WordPress plugins",
  "type": "project",
  "license": "MIT",
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "php-stubs/wordpress-stubs": "^6.7"
  },
  "autoload-dev": {
    "classmap": [
      "tests/php/"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
