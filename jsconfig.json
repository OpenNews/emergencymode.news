{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleDetection": "force",
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "allowJs": true,
    "lib": ["DOM", "ES2022"]
  },
  "include": ["plugins/**/*.js", "plugins/**/*.d.ts"],
  "exclude": ["node_modules", ".venv", "tmp"]
}
